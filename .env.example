# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Alpaca Paper Trading (https://app.alpaca.markets/paper/dashboard/overview)
# Preferred: distinct env vars for paper. The legacy ALPACA_API_KEY /
# ALPACA_API_SECRET below are still accepted as fallback by
# src/execution/alpaca.py for backwards compat.
ALPACA_PAPER_API_KEY=your_paper_api_key_here
ALPACA_PAPER_API_SECRET=your_paper_api_secret_here
# (legacy aliases — accepted as fallback when the PAPER_ ones are absent)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_API_SECRET=your_paper_api_secret_here

# Alpaca LIVE Trading — DISABLED by default. To enable, ALL THREE must
# be set:
#   1. ALPACA_LIVE_API_KEY + ALPACA_LIVE_API_SECRET (distinct from
#      paper keys; a single env-var leak cannot route paper traffic
#      to live)
#   2. ALPACA_LIVE_TRADING_CONFIRMED=1 (separate consent toggle)
#   3. Call site passes paper=False to AlpacaClient explicitly
# All three are checked at construction time and raise loudly if any
# is missing. Do NOT uncomment unless you intend real-money trading.
# ALPACA_LIVE_API_KEY=your_live_api_key_here
# ALPACA_LIVE_API_SECRET=your_live_api_secret_here
# ALPACA_LIVE_TRADING_CONFIRMED=0

# Anthropic Claude (research agent + pre-trade sanity check)
# Required for src/research_agent/* and the /research page. Without it
# the agent ships but raises at the first LLM call.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SEC EDGAR — required by src/market_data/edgar/* and the filing event
# monitor. Format: "AppName your.email@domain" (SEC requires real contact
# info; anonymous traffic gets IP-banned).
STOCKNEW_EDGAR_USER_AGENT="StockNew erand1998@gmail.com"
